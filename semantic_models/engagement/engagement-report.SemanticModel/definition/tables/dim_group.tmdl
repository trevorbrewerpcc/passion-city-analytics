table dim_group
	lineageTag: 51862b62-94c4-40f9-bfb0-46217c4a94d2

	measure socialsignupsP5W = COALESCE(CALCULATE(DISTINCTCOUNT(dim_groupmember[PersonId]),filter(dim_groupmember,dim_groupmember[GroupTypeId]=173 && dim_groupmember[CreatedDateTime]>=now()-35)),"-")
		formatString: #,0
		lineageTag: 53bd5e17-f6ad-46a4-981e-ab04b81136a0

		annotation PBI_FormatHint = {"isDecimal":true}

	measure meetingsP5W = COALESCE(CALCULATE(sum(dim_group[socialsP5W]),dim_group[grouptypeid]=173),"-")
		formatString: #,0
		lineageTag: 9a4becd2-99c5-41f1-bbb8-79d127fb29b8

		annotation PBI_FormatHint = {"isDecimal":true}

	measure P5WCheckIns = ```
			COUNTROWS(
			        FILTER(
			            fact_checkin,
			            fact_checkin[AOOccurrenceDate] > TODAY() - 35
			                && fact_checkin[ADidAttend] = TRUE()
			                && fact_checkin[GTId] IN {19,20,60,68,69,85,128}
			        )
			    )
			
			```
		formatString: #,0
		lineageTag: 92386163-8bce-4fc3-979d-6749114e2c96

	measure YTDCheckIns = ```
			COUNTROWS(
			        FILTER(
			            fact_checkin,
			            year(fact_checkin[AOOccurrenceDate]) = year(now())
			                && fact_checkin[ADidAttend] = TRUE()
			                && fact_checkin[GTId] IN {19,20,60,68,69,85,128}
			        )
			    )
			
			```
		formatString: #,0
		lineageTag: 4314b764-d2f7-4695-8170-dfd0f37116a2

	measure P5WNewCheckIns = ```
			COUNTROWS(
			        FILTER(
			            fact_checkin,
			            fact_checkin[AOOccurrenceDate] > TODAY() - 35
			                && fact_checkin[ADidAttend] = TRUE()
			                && fact_checkin[GTId] IN {19,20,60,68,69,85,128}
			                && fact_checkin[AIsFirstTime] = TRUE()
			        )
			    )
			
			```
		formatString: 0
		lineageTag: 4f24c606-88ed-4f2b-becd-f33de01fa737

	measure YTDNewCheckIns = ```
			COUNTROWS(
			        FILTER(
			            fact_checkin,
			            year(fact_checkin[AOOccurrenceDate]) = year(now())
			                && fact_checkin[ADidAttend] = TRUE()
			                && fact_checkin[GTId] IN {19,20,60,68,69,85,128}
			                && fact_checkin[AIsFirstTime] = TRUE()
			        )
			    )
			
			```
		formatString: #,0
		lineageTag: f11f1f88-600d-4f66-b647-3d3859975669

	/// Text range: 5 weeks ago - today
	measure P5W_DateRange = FORMAT(TODAY()-35, "MM/dd") & " - " & FORMAT(TODAY(), "MM/dd")
		displayFolder: Measures
		lineageTag: 6ffc6c92-d9ee-44d5-a9ab-0f1c80383929

	/// Latest check-in date for group type 36 formatted MM/dd
	measure G36_LatestCheckin_MMDD =
			IF(
			    ISBLANK(
			        MAXX(
			            FILTER(ALL(fact_checkin), LOOKUPVALUE(dim_group[grouptypeid], dim_group[groupid], fact_checkin[GId]) = 36),
			            fact_checkin[AOOccurrenceDate]
			        )
			    ),
			    "-",
			    "Last Checkin - " & FORMAT(
			        MAXX(
			            FILTER(ALL(fact_checkin), LOOKUPVALUE(dim_group[grouptypeid], dim_group[groupid], fact_checkin[GId]) = 36),
			            fact_checkin[AOOccurrenceDate]
			        ),
			        "MM/dd"
			    )
			)
		displayFolder: Measures
		lineageTag: df1dea3b-bc4f-497c-bef9-b92c38c41b05


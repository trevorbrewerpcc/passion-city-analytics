	column SocialStartDate
		dataType: dateTime
		formatString: Long Date
		lineageTag: b9a8022d-c432-43eb-a3e6-5eb387ef5087
		summarizeBy: none
		sourceColumn: SocialStartDate

		variation Variation
			isDefault
			relationship: 31c76bec-2528-4bf2-bfa9-36c141eac244
			defaultHierarchy: LocalDateTable_23fcdc83-7553-4a01-922d-68f6cdb06453.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column socialsP5W =
			
			VAR TodayDate = TODAY()
			VAR PeriodStart = TodayDate - 35
			VAR StartDateRaw = dim_group[SocialStartDate]
			VAR StartDate = IF(ISBLANK(StartDateRaw), TodayDate + 1, DATEVALUE(StartDateRaw))
			VAR Rhythm = dim_group[MeetingRhythm]
			VAR Dates =
			    SWITCH(
			        Rhythm,
			        "once",
			            IF(StartDate >= PeriodStart && StartDate <= TodayDate, 1, 0),
			        "weekly",
			            COUNTX(
			                GENERATESERIES(StartDate, TodayDate, 7),
			                IF([Value] >= PeriodStart && [Value] <= TodayDate, 1, BLANK())
			            ),
			        "every other week",
			            COUNTX(
			                GENERATESERIES(StartDate, TodayDate, 14),
			                IF([Value] >= PeriodStart && [Value] <= TodayDate, 1, BLANK())
			            ),
			        "monthly",
			            COUNTX(
			                ADDCOLUMNS(
			                    GENERATESERIES(0, DATEDIFF(StartDate, TodayDate, MONTH)),
			                    "Date", EDATE(StartDate, [Value])
			                ),
			                IF([Date] >= PeriodStart && [Date] <= TodayDate, 1, BLANK())
			            ),
			        0
			    )
			RETURN Dates
		formatString: 0
		lineageTag: 2d702014-7d95-4000-a2bf-71eeb3da0db9
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column HasSundayCheckins =
			VAR gid = dim_group[groupid]
			VAR AnyRequested = COUNTROWS(FILTER(ALL(fact_checkin), fact_checkin[GId] = gid && fact_checkin[ARequestedToAttend] = TRUE())) > 0
			VAR NonSundayCount = COUNTROWS(FILTER(ALL(fact_checkin), fact_checkin[GId] = gid && fact_checkin[Sunday] <> 1))
			RETURN IF(AnyRequested && NonSundayCount = 0, 1, 0)
		dataType: int64
		formatString: 0
		lineageTag: 756c2b81-4648-4993-940a-54abf6b93dbd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic


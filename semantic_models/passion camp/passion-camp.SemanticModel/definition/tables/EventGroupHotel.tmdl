	column 'Hotel Name'
		lineageTag: 7689fac5-204e-4165-b720-4cff1e77d64e
		summarizeBy: none
		isNameInferred
		sourceColumn: [Hotel Name]

		annotation SummarizationSetBy = Automatic

	column 'Event Group ID'
		formatString: 0
		lineageTag: ef4e8d3c-7230-4628-bd4e-e6b756d0623e
		summarizeBy: none
		isNameInferred
		sourceColumn: [Event Group ID]

		annotation SummarizationSetBy = Automatic

	partition EventGroupHotel = calculated
		mode: import
		source =
				
				SELECTCOLUMNS(
				    GENERATE(
				        GENERATE(
				            events,
				            FILTER(event_groups, event_groups[event_id] = events[id])
				        ),
				        FILTER(event_hotels, event_hotels[event_id] = events[id])
				    ),
				    "Event ID", events[id],
				    "Event Name", events[name],
				    "Group ID", event_groups[group_id],
				    "Group Name", LOOKUPVALUE(groups[name], groups[id], event_groups[group_id]),
				    "Event Group ID", event_groups[id],
				    "Hotel ID", event_hotels[hotel_id],
				    "Hotel Name", LOOKUPVALUE(hotels[name], hotels[id], event_hotels[hotel_id])
				)


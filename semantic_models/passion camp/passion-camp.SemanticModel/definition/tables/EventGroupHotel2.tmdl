	partition EventGroupHotel2 = calculated
		mode: import
		source =
				
				SELECTCOLUMNS(
				    FILTER(orders, orders[orderable_type_simplified] = "Hotel" && ISBLANK(orders[deleted_at])),
				    "Order ID", orders[id],
				    "Orderable ID", orders[orderable_id],
				    "Hotel ID", LOOKUPVALUE(event_hotels[hotel_id],event_hotels[id],orders[orderable_id]),
				    "Event ID", LOOKUPVALUE(event_hotels[event_id],event_hotels[id],orders[orderable_id]),
				    "Event Name", LOOKUPVALUE(events[name],events[id],LOOKUPVALUE(event_hotels[event_id],event_hotels[id],orders[orderable_id])),
				    "Hotel Name", LOOKUPVALUE(hotels[name],hotels[id],LOOKUPVALUE(event_hotels[hotel_id],event_hotels[id],orders[orderable_id])),
				    "Event Group ID", orders[event_group_id],
				    "Group Name", LOOKUPVALUE(groups[name], groups[id], LOOKUPVALUE(event_groups[group_id],event_groups[id],orders[event_group_id]))
				    // "Event Group ID", event_groups[id],
				    // "Hotel ID", event_hotels[hotel_id],
				    // "Hotel Name", LOOKUPVALUE(hotels[name], hotels[id], event_hotels[hotel_id])
				)

	annotation PBI_Id = 83af9f85de274a888ecf1415f12be120

